<Window x:Class="TaskManager.WPF.Views.TaskEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Задача" Height="555" Width="391"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <Border Margin="16" Background="{StaticResource CardBrush}"
            CornerRadius="6" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0" x:Name="WindowTitle"
                       Text="Новая задача" FontSize="16" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,16"/>

            <!-- Название -->
            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <TextBlock Text="Название *" FontSize="12"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleBox"/>
            </StackPanel>

            <!-- Описание -->
            <StackPanel Grid.Row="2" Margin="0,0,0,10">
                <TextBlock Text="Описание" FontSize="12"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="DescriptionBox" Height="60"
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </StackPanel>

            <!-- Приоритет -->
            <StackPanel Grid.Row="3" Margin="0,0,0,10">
                <TextBlock Text="Приоритет" FontSize="12"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="PriorityComboBox">
                    <ComboBoxItem Content="Низкий"/>
                    <ComboBoxItem Content="Средний" IsSelected="True"/>
                    <ComboBoxItem Content="Высокий"/>
                </ComboBox>
            </StackPanel>

            <!-- Статус -->
            <StackPanel Grid.Row="4" Margin="0,0,0,10">
                <TextBlock Text="Статус" FontSize="12"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                <ComboBox x:Name="StatusComboBox">
                    <ComboBoxItem Content="Новая" IsSelected="True"/>
                    <ComboBoxItem Content="В процессе"/>
                    <ComboBoxItem Content="Завершена"/>
                </ComboBox>
            </StackPanel>

            <!-- Срок выполнения -->
            <StackPanel Grid.Row="5" Margin="0,0,0,10">
                <TextBlock Text="Срок выполнения" FontSize="12"
                           Foreground="{StaticResource SubtextBrush}" Margin="0,0,0,4"/>
                <DatePicker x:Name="DueDatePicker" FontSize="13"/>
            </StackPanel>

            <!-- Важная -->
            <CheckBox Grid.Row="6" x:Name="ImportantCheckBox"
                      Content="⭐ Отметить как Важную"
                      FontSize="13" Foreground="{StaticResource TextBrush}"
                      VerticalAlignment="Center" Margin="0,4,0,0"/>

            <!-- Кнопки -->
            <StackPanel Grid.Row="7" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Отмена" Width="90" Margin="0,0,8,0"
                        Click="Cancel_Click"
                        Style="{StaticResource PrimaryButton}"
                        Background="#9E9E9E"/>
                <Button Content="Сохранить" Width="90"
                        Style="{StaticResource PrimaryButton}"
                        Click="Save_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
